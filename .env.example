# Copy this file to .env and fill in the values
# cp .env.example .env

############################################################
# PostgreSQL — password for all DB service accounts
############################################################
POSTGRES_PASSWORD=your_strong_password_here

############################################################
# JWT secret — signs all auth tokens (keep it secret!)
############################################################
JWT_SECRET=your_long_random_jwt_secret_here

############################################################
# Supabase keys — generate from JWT_SECRET using the script:
#   node scripts/generate-keys.mjs
############################################################
ANON_KEY=
SERVICE_ROLE_KEY=

############################################################
# Anthropic API key (optional — enables AI descriptions)
############################################################
# ANTHROPIC_API_KEY=sk-ant-...
